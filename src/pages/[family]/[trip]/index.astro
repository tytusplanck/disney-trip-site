---
import { allTripsData } from '../../../data/all-trips';
import { findTripSummary, getTripLandingPath } from '../../../lib/trips/all-trips';

const familyId = Astro.params['family'] ?? '';
const tripId = Astro.params['trip'] ?? '';
const trip = findTripSummary(allTripsData.trips, familyId, tripId);

if (!trip) {
  return Astro.redirect('/');
}

const tripLandingPath = getTripLandingPath(trip);

if (tripLandingPath === '') {
  return Astro.redirect('/');
}

return Astro.redirect(tripLandingPath);
---
