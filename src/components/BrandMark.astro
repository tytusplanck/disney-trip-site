---
import { siteShellData } from '../data/site-shell';

interface Props {
  href?: string;
}

const { href = '/' } = Astro.props;
---

<a class="brand-mark" href={href} aria-label={siteShellData.brandLinkLabel}>
  <span class="brand-mark__wordmark">Disney</span>
  <span class="brand-mark__route" aria-hidden="true"></span>
  <span class="brand-mark__support">Planned by Tytus</span>
</a>
