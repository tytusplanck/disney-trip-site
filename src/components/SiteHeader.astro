---
import BrandMark from './BrandMark.astro';

interface StatItem {
  label: string;
  value: string;
}

type HeaderKind = 'archive' | 'trip';

interface Props {
  headerKind: HeaderKind;
  railLabel: string;
  statItems: StatItem[];
  stickyMode?: 'none' | 'all' | 'mobile' | undefined;
  mobileTitle?: string | undefined;
  mobileBackHref?: string | undefined;
  mobileBackLabel?: string | undefined;
  mobileFactsLabel?: string | undefined;
  mobileFactsItems?: StatItem[] | undefined;
}

const {
  headerKind,
  railLabel,
  statItems,
  stickyMode = 'none',
  mobileTitle,
  mobileBackHref,
  mobileBackLabel,
  mobileFactsLabel,
  mobileFactsItems = [],
} = Astro.props;
const hasMobileFacts = mobileFactsItems.length > 0 && typeof mobileFactsLabel === 'string';
const fullMobileTitle = mobileTitle ?? railLabel;
---

<header
  class:list={[
    'site-header',
    stickyMode === 'all' && 'site-header--sticky-all',
    stickyMode === 'mobile' && 'site-header--sticky-mobile',
  ]}
  data-header-kind={headerKind}
>
  <div class="site-header__desktop">
    <div class="site-header__top">
      <div class="site-header__brand-block">
        <BrandMark />
        <div class="site-header__context">
          <slot name="context" />
        </div>
      </div>
      {headerKind === 'trip' && <p class="site-header__trip-label">{railLabel}</p>}
    </div>
    <section
      class:list={['site-header__rail', headerKind === 'trip' && 'site-header__rail--trip']}
      aria-label={railLabel}
    >
      <div class="site-header__rail-heading">
        <p class="site-header__rail-title">{railLabel}</p>
        {
          headerKind === 'trip' && mobileTitle && (
            <p class="site-header__rail-subtitle" title={mobileTitle}>
              {mobileTitle}
            </p>
          )
        }
      </div>
      <dl class="site-header__stats site-header__stats--summary">
        {
          statItems.map((item) => (
            <div class="site-header__stat">
              <dt class="site-header__rail-label">{item.label}</dt>
              <dd class="site-header__rail-value">{item.value}</dd>
            </div>
          ))
        }
      </dl>
    </section>
  </div>

  {
    headerKind === 'trip' ? (
      <div class="site-header__mobile site-header__mobile--trip">
        <a class="site-header__mobile-back" href={mobileBackHref}>
          {mobileBackLabel}
        </a>
        <div class="site-header__mobile-title-block">
          <p class="site-header__mobile-kicker">{railLabel}</p>
          <p class="site-header__mobile-title" title={fullMobileTitle} aria-label={fullMobileTitle}>
            {mobileTitle}
          </p>
        </div>
        {hasMobileFacts && (
          <details
            class="site-header__mobile-facts-shell"
            data-mobile-behavior="collapsed"
            data-desktop-default-open="true"
            open
          >
            <summary class="site-header__mobile-facts-summary">
              <span class="site-header__mobile-facts-summary-label">{mobileFactsLabel}</span>
              <span class="site-header__mobile-facts-toggle" aria-hidden="true" />
            </summary>
            <div class="site-header__mobile-facts-panel">
              <div class="site-header__mobile-facts-grid">
                {mobileFactsItems.map((item) => (
                  <div class="site-header__mobile-fact">
                    <span class="site-header__mobile-fact-label">{item.label}</span>
                    <strong class="site-header__mobile-fact-value">{item.value}</strong>
                  </div>
                ))}
              </div>
            </div>
          </details>
        )}
      </div>
    ) : (
      <div class="site-header__mobile site-header__mobile--archive">
        <div class="site-header__mobile-brand-block">
          <BrandMark />
          <p class="site-header__mobile-kicker">{railLabel}</p>
        </div>
        {hasMobileFacts && (
          <details
            class="site-header__mobile-facts-shell"
            data-mobile-behavior="collapsed"
            data-desktop-default-open="true"
            open
          >
            <summary class="site-header__mobile-facts-summary">
              <span class="site-header__mobile-facts-summary-label">{mobileFactsLabel}</span>
              <span class="site-header__mobile-facts-toggle" aria-hidden="true" />
            </summary>
            <div class="site-header__mobile-facts-panel">
              <div class="site-header__mobile-facts-grid">
                {mobileFactsItems.map((item) => (
                  <div class="site-header__mobile-fact">
                    <span class="site-header__mobile-fact-label">{item.label}</span>
                    <strong class="site-header__mobile-fact-value">{item.value}</strong>
                  </div>
                ))}
              </div>
            </div>
          </details>
        )}
      </div>
    )
  }
</header>
