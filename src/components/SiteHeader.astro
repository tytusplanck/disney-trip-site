---
import BrandMark from './BrandMark.astro';

type HeaderKind = 'archive' | 'trip';

interface Props {
  headerKind: HeaderKind;
  contextLabel?: string | undefined;
  stickyMode?: 'none' | 'all' | 'mobile' | undefined;
  mobileTitle?: string | undefined;
  mobileBackHref?: string | undefined;
  mobileBackLabel?: string | undefined;
}

const {
  headerKind,
  contextLabel,
  stickyMode = 'none',
  mobileTitle,
  mobileBackHref,
  mobileBackLabel,
} = Astro.props;
---

<header
  class:list={[
    'site-header',
    stickyMode === 'all' && 'site-header--sticky-all',
    stickyMode === 'mobile' && 'site-header--sticky-mobile',
  ]}
  data-header-kind={headerKind}
>
  <div class="site-header__desktop">
    <div class="site-header__top">
      <BrandMark />
      {
        headerKind === 'trip' ? (
          <div class="site-header__context">
            <slot name="context" />
          </div>
        ) : (
          contextLabel && <p class="site-header__context-text">{contextLabel}</p>
        )
      }
    </div>
  </div>

  {
    headerKind === 'trip' ? (
      <div class="site-header__mobile site-header__mobile--trip">
        <a class="site-header__mobile-back" href={mobileBackHref}>
          {mobileBackLabel}
        </a>
        {mobileTitle && (
          <div class="site-header__mobile-title-block">
            <p class="site-header__mobile-title" title={mobileTitle} aria-label={mobileTitle}>
              {mobileTitle}
            </p>
          </div>
        )}
      </div>
    ) : (
      <div class="site-header__mobile site-header__mobile--archive">
        <div class="site-header__mobile-brand-block">
          <BrandMark />
          {contextLabel && <p class="site-header__mobile-kicker">{contextLabel}</p>}
        </div>
      </div>
    )
  }
</header>
