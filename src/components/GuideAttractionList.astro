---
import type { GuideAttraction } from '../lib/trips/types';

interface Props {
  attractions: GuideAttraction[];
}

const { attractions } = Astro.props;

const priorityMeta: Record<
  GuideAttraction['priority'],
  { label: string; tone: 'must' | 'recommended' | 'if-time' | 'skip' }
> = {
  'must-do': { label: 'Must Do', tone: 'must' },
  recommended: { label: 'Recommended', tone: 'recommended' },
  'if-time': { label: 'If Time', tone: 'if-time' },
  skip: { label: 'Skip', tone: 'skip' },
};
---

<ul class="guide-attraction-list">
  {
    attractions.map((attraction) => {
      const meta = priorityMeta[attraction.priority];
      return (
        <li class="guide-attraction-card" data-priority={attraction.priority}>
          <div class="guide-attraction-card__header">
            <div class="guide-attraction-card__title-row">
              <h3 class="guide-attraction-card__name">{attraction.attractionLabel}</h3>
              <span class="guide-attraction-card__badge" data-tone={meta.tone}>
                {meta.label}
              </span>
            </div>
            <p class="guide-attraction-card__area">{attraction.areaLabel}</p>
          </div>
          <p class="guide-attraction-card__notes">{attraction.notes}</p>
        </li>
      );
    })
  }
</ul>
