---
interface Props {
  label?: string | undefined;
  summary: string;
  detail: string;
  mobileBehavior?: 'expanded' | 'collapsed' | 'match-desktop' | undefined;
  defaultOpen?: boolean | undefined;
}

const {
  label,
  summary,
  detail,
  mobileBehavior = 'match-desktop',
  defaultOpen = true,
} = Astro.props;
---

<details
  class="disclosure-panel"
  data-mobile-behavior={mobileBehavior}
  data-desktop-default-open={defaultOpen ? 'true' : 'false'}
  open={defaultOpen}
>
  <summary class="disclosure-panel__summary">
    <span class="disclosure-panel__summary-copy">
      {label && <span class="disclosure-panel__label">{label}</span>}
      <span class="disclosure-panel__headline">{summary}</span>
      <span class="disclosure-panel__detail">{detail}</span>
    </span>
    <span class="disclosure-panel__toggle" aria-hidden="true"></span>
  </summary>

  <div class="disclosure-panel__body">
    <slot />
  </div>
</details>
