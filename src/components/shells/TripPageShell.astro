---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../Breadcrumbs.astro';
import SiteHeader from '../SiteHeader.astro';
import TripTabs from '../TripTabs.astro';
import type { TripSection, TripSummary } from '../../lib/trips/types';

interface Props {
  title: string;
  description: string;
  trip: TripSummary;
  activeSection: TripSection;
  pageTitle: string;
  pageSummary?: string | undefined;
}

const { title, description, trip, activeSection, pageTitle, pageSummary } = Astro.props;

const tripLabel = `${trip.title} / ${trip.dateLabel}`;
---

<BaseLayout title={title} description={description}>
  <div class="trip-shell" data-trip-theme={trip.themeId}>
    <SiteHeader
      headerKind="trip"
      stickyMode="mobile"
      mobileTitle={trip.title}
      mobileBackHref="/"
      mobileBackLabel="Back to trips"
    >
      <Breadcrumbs slot="context" tripLabel={tripLabel} />
    </SiteHeader>

    <main class="trip-shell__main trip-page-shell__main" id="main-content">
      <TripTabs trip={trip} activeSection={activeSection} />
      <section class="trip-page-heading">
        <h1 class="page-title trip-page-heading__title">{pageTitle}</h1>
        {pageSummary && <p class="body-copy trip-page-heading__summary">{pageSummary}</p>}
      </section>
      <slot />
    </main>
  </div>
</BaseLayout>
