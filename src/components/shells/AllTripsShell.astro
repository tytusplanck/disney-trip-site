---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../SiteHeader.astro';

interface Props {
  title: string;
  description: string;
  metaLabel: string;
  footerNote: string;
}

const { title, description, metaLabel, footerNote } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div class="all-trips-shell">
    <SiteHeader headerKind="archive" contextLabel={metaLabel} />
    <main class="all-trips-main" id="main-content">
      <slot />
    </main>
    <footer class="all-trips-footer">
      <p class="all-trips-footer__brand">Disney Planned by Tytus</p>
      <p class="all-trips-footer__note">{footerNote}</p>
    </footer>
  </div>
</BaseLayout>
