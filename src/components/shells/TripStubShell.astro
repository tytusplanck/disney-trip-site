---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../Breadcrumbs.astro';
import SiteHeader from '../SiteHeader.astro';
import TripTabs from '../TripTabs.astro';
import type { TripSection, TripSectionTab, TripSummary } from '../../lib/trips/types';

interface Props {
  title: string;
  description: string;
  trip: TripSummary;
  activeSection?: TripSection;
  pageTitle: string;
  panelEyebrow: string;
  panelTitle: string;
  panelBody: string;
  checklist: string[];
  sectionConfig?: TripSectionTab[] | undefined;
}

const {
  title,
  description,
  trip,
  activeSection,
  pageTitle,
  panelEyebrow,
  panelTitle,
  panelBody,
  checklist,
  sectionConfig,
} = Astro.props;

const tripLabel = `${trip.title} / ${trip.dateLabel}`;
---

<BaseLayout title={title} description={description}>
  <div class="trip-shell" data-trip-theme={trip.themeId}>
    <SiteHeader
      headerKind="trip"
      stickyMode="mobile"
      mobileTitle={trip.title}
      mobileBackHref="/"
      mobileBackLabel="Back to trips"
    >
      <Breadcrumbs slot="context" tripLabel={tripLabel} />
    </SiteHeader>

    <main class="trip-shell__main" id="main-content">
      <h1 class="visually-hidden">{pageTitle}</h1>
      <TripTabs trip={trip} activeSection={activeSection} sectionConfig={sectionConfig} />
      <section class="stub-panel">
        <div class="stub-panel__header">
          <p class="stub-panel__eyebrow">{panelEyebrow}</p>
          <h2 class="stub-panel__title">{panelTitle}</h2>
          <p class="stub-panel__body">{panelBody}</p>
        </div>

        <div class="stub-panel__rail">
          <p class="stub-panel__rail-title">Next build items</p>
          <ul class="stub-panel__checklist">
            {checklist.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      </section>
    </main>
  </div>
</BaseLayout>
