---
import StatusBadge from './StatusBadge.astro';
import {
  findTripDataModule,
  getTripCompactFactsLine,
  getTripLandingPath,
} from '../lib/trips/all-trips';
import type { TripSummary } from '../lib/trips/types';
import { getAllTripsCardPresentation, type AllTripsCardCopy } from '../pages/index.page';
import { allTripsData } from '../data/all-trips';

interface Props {
  trip: TripSummary;
  copy: AllTripsCardCopy;
}

const { trip, copy } = Astro.props;

const tripModule = findTripDataModule(allTripsData.modules, trip.slug);
const cardHref = getTripLandingPath(trip, tripModule);
const cardPresentation = getAllTripsCardPresentation(copy, trip.status);
const factsLine = getTripCompactFactsLine(trip);
---

<article class="trip-card" data-trip-theme={trip.themeId} data-trip-status={trip.status}>
  <div class="trip-card__route" aria-hidden="true"></div>

  <header class="trip-card__header">
    <StatusBadge status={trip.status} />
    <h3 class="trip-card__title">{trip.title}</h3>
    <p class="trip-card__date">{trip.dateLabel}</p>
  </header>

  <a class="trip-card__button" href={cardHref}>
    {cardPresentation.primaryActionLabel}
  </a>

  <p class="trip-card__facts">{factsLine}</p>
</article>
