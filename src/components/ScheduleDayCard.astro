---
import type { ScheduleDaySummary } from '../lib/trips/details';
interface Props {
  day: ScheduleDaySummary;
  isToday?: boolean;
}

const { day, isToday = false } = Astro.props;
---

<article class="schedule-card" data-kind={day.entry.kind} data-today={isToday ? 'true' : undefined}>
  <div class="schedule-card__day">
    <span class="schedule-card__day-index">Day {day.dayNumber}</span>
    <span class="schedule-card__day-marker" aria-hidden="true"></span>
  </div>

  <div class="schedule-card__body">
    <div class="schedule-card__meta">
      <p class="schedule-card__date">
        {day.weekdayLabel} / {day.dateLabel}
      </p>
      <div class="schedule-card__kinds">
        {
          day.badges.map((badge) => (
            <p class:list={['schedule-card__kind', `schedule-card__kind--${badge.kind}`]}>
              {badge.label}
            </p>
          ))
        }
      </div>
    </div>
    <h3 class="schedule-card__title">{day.entry.label}</h3>
    {
      day.badges.length === 1 && day.entry.parkLabel && day.entry.parkLabel !== day.entry.label && (
        <p class="schedule-card__park">{day.entry.parkLabel}</p>
      )
    }
    {day.entry.notes && <p class="schedule-card__note">{day.entry.notes}</p>}
  </div>
</article>
